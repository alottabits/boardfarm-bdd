		{
			"id": "BrPdAPa4",
			"type": "text",
			"x": -450,
			"y": -80,
			"width": 368.78472900390625,
			"height": 400,
			"backgroundColor": "transparent",
			"strokeColor": "#868e96",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
			"text": "Dashed boxes = OVS bridges (Raikou)\nRounded boxes = Docker containers\nAll test traffic via Raikou OVS\nManagement: OVS mgmt bridge 192.168.55.0/24\n\napp-router: CONNMARK policy routing\n  symmetric return paths per WAN\n\nBoardfarm automation:\n  Edge ← LinuxSDWANRouter\n  TCs ← LinuxTrafficController\n  Client ← QoEClient\n  TGs ← IperfTrafficGenerator\n\nEndpoints (from LAN):\n  http(s)://172.16.0.10 (prod)\n  http(s)://172.16.0.11 (stream)\n  wss://172.16.0.12:8443 (conf)\n  172.16.0.20 (IPsec hub)\n  172.16.0.25 (north TG)",
			"fontSize": 16,
			"fontFamily": 5,
			"groupIds": [],
			"locked": false,
			"roundness": null,
			"fillStyle": "solid",
			"boundElements": [],
			"createdAt": "2026-03-30T14:10:23.962Z",
			"updatedAt": "2026-03-30T14:10:50.384Z",
			"version": 8,
			"containerId": null,
			"originalText": "Dashed boxes = OVS bridges (Raikou)\nRounded boxes = Docker containers\nAll test traffic via Raikou OVS\nManagement: OVS mgmt bridge 192.168.55.0/24\n\napp-router: CONNMARK policy routing\n  symmetric return paths per WAN\n\nBoardfarm automation:\n  Edge ← LinuxSDWANRouter\n  TCs ← LinuxTrafficController\n  Client ← QoEClient\n  TGs ← IperfTrafficGenerator\n\nEndpoints (from LAN):\n  http(s)://172.16.0.10 (prod)\n  http(s)://172.16.0.11 (stream)\n  wss://172.16.0.12:8443 (conf)\n  172.16.0.20 (IPsec hub)\n  172.16.0.25 (north TG)",
			"autoResize": true,
			"lineHeight": 1.25,
			"versionNonce": 1032609067,
			"index": "a1",
			"isDeleted": false,
			"angle": 0,
			"seed": 1,
			"frameId": null,
			"updated": 1774882458423,
			"hasTextLink": false,
			"rawText": "Dashed boxes = OVS bridges (Raikou)\nRounded boxes = Docker containers\nAll test traffic via Raikou OVS\nManagement: OVS mgmt bridge 192.168.55.0/24\n\napp-router: CONNMARK policy routing\n  symmetric return paths per WAN\n\nBoardfarm automation:\n  Edge ← LinuxSDWANRouter\n  TCs ← LinuxTrafficController\n  Client ← QoEClient\n  TGs ← IperfTrafficGenerator\n\nEndpoints (from LAN):\n  http(s)://172.16.0.10 (prod)\n  http(s)://172.16.0.11 (stream)\n  wss://172.16.0.12:8443 (conf)\n  172.16.0.20 (IPsec hub)\n  172.16.0.25 (north TG)",
