			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
			"text": "Dual-WAN SD-WAN Testbed Topology",
			"fontSize": 28,
			"fontFamily": 5,
			"groupIds": [],
			"locked": false,
			"roundness": null,
			"fillStyle": "solid",
			"boundElements": [],
