      "groupIds": [],
      "index": "a55",
      "roundness": null,
      "seed": 2111,
      "version": 1,
      "versionNonce": 2112,
      "boundElements": [],
      "text": "Visual Conventions:\n\u2022 Rounded boxes = containers\n\u2022 Green = central (Router)\n\u2022 Purple = ISP infrastructure\n\u2022 Yellow = CPE\n\u2022 Blue = client devices\n\u2022 Dashed bars = OVS bridges\n\nArrows show interface\nconnections to bridges",
      "rawText": "Visual Conventions:\n\u2022 Rounded boxes = containers\n\u2022 Green = central (Router)\n\u2022 Purple = ISP infrastructure\n\u2022 Yellow = CPE\n\u2022 Blue = client devices\n\u2022 Dashed bars = OVS bridges\n\nArrows show interface\nconnections to bridges",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Visual Conventions:\n\u2022 Rounded boxes = containers\n\u2022 Green = central (Router)\n\u2022 Purple = ISP infrastructure\n\u2022 Yellow = CPE\n\u2022 Blue = client devices\n\u2022 Dashed bars = OVS bridges\n\nArrows show interface\nconnections to bridges",
      "autoResize": true,
      "lineHeight": 1.25,
      "hasTextLink": false,
      "angle": 0,
      "fillStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "frameId": null,
