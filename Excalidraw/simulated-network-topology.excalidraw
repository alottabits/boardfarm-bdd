    {
      "id": "text-annotation-conventions",
      "type": "text",
      "x": -420,
      "y": 0,
      "width": 260,
      "height": 280,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "strokeWidth": 2,
