      "version": 1,
      "versionNonce": 1098,
      "boundElements": [],
      "text": "Visual Conventions:\n\u2022 Rounded boxes = containers\n\u2022 Green = host / management\n\u2022 Purple = infrastructure\n\u2022 Yellow = CPE\n\u2022 Blue = client devices\n\u2022 Dashed bar = OVS bridge\n\nAll containers use\nnetwork_mode: none",
      "rawText": "Visual Conventions:\n\u2022 Rounded boxes = containers\n\u2022 Green = host / management\n\u2022 Purple = infrastructure\n\u2022 Yellow = CPE\n\u2022 Blue = client devices\n\u2022 Dashed bar = OVS bridge\n\nAll containers use\nnetwork_mode: none",
