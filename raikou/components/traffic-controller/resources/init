#!/bin/bash -e
#
# Traffic Controller init script
# Waits for Raikou-injected eth-dut and eth-north,
# enables IP forwarding, then starts SSH.
# tc netem is applied at runtime by the LinuxTrafficController driver (per-direction: eth-north + eth-dut).
#
# See: docs/Traffic_Management_Components_Architecture.md
#

DUT_IFACE="${TC_DUT_IFACE:-eth-dut}"
NORTH_IFACE="${TC_NORTH_IFACE:-eth-north}"

wait_for_iface() {
    local iface=$1
    local count=0
    while [ ! -d "/sys/class/net/$iface" ] && [ $count -lt 60 ]; do
        echo "Waiting for $iface..."
        sleep 2
        count=$((count + 1))
    done
    if [ ! -d "/sys/class/net/$iface" ]; then
        echo "ERROR: $iface not found after 120s"
        exit 1
    fi
    ip link set "$iface" up
    echo "$iface is up"
}

echo "Waiting for Raikou-injected interfaces..."
wait_for_iface "$DUT_IFACE"
wait_for_iface "$NORTH_IFACE"

# Enable IP forwarding so traffic flows DUT ↔ eth-dut ↔ eth-north ↔ north-segment (Raikou OVS)
sysctl -p /etc/sysctl.conf 2>/dev/null || true

# Route return traffic: north-segment replies to lan-segment (192.168.10.0/24) must go via DUT
DUT_GW=$(ip -4 addr show dev "$DUT_IFACE" 2>/dev/null | grep -oP 'inet \K[\d.]+' | head -1)
if [ -n "$DUT_GW" ]; then
    DUT_GW="${DUT_GW%.*}.1"
    ip route add 192.168.10.0/24 via "$DUT_GW" dev "$DUT_IFACE" 2>/dev/null || true
fi

echo "Traffic Controller ready. Starting SSH..."
exec /usr/sbin/sshd -D
