#!/bin/bash -xe
#
# SD-WAN Router init script
# Waits for Raikou-injected interfaces (eth-lan, eth-wan1, eth-wan2),
# brings them up, starts FRR with BFD failover, starts StrongSwan
# (Phase 3.5 — if certs are mounted), then sshd.
#
# Container uses network_mode: none — no Docker management interface.
# Boardfarm accesses via docker exec.
#

LAN_IFACE="${LAN_IFACE:-eth-lan}"
WAN1_IFACE="${WAN1_IFACE:-eth-wan1}"
WAN2_IFACE="${WAN2_IFACE:-eth-wan2}"

wait_for_iface() {
    local iface=$1
    local count=0
    while [ ! -d "/sys/class/net/$iface" ] && [ $count -lt 60 ]; do
        echo "Waiting for $iface..."
        sleep 2
        count=$((count + 1))
    done
    if [ ! -d "/sys/class/net/$iface" ]; then
        echo "ERROR: $iface not found after 120s"
        exit 1
    fi
    ip link set "$iface" up
    echo "$iface is up"
}

echo "Waiting for Raikou-injected interfaces..."
wait_for_iface "$LAN_IFACE"
wait_for_iface "$WAN1_IFACE"
wait_for_iface "$WAN2_IFACE"

# Apply sysctl for IP forwarding
sysctl -p /etc/sysctl.conf 2>/dev/null || true

# Ensure FRR daemons are enabled (zebra, staticd, bfdd, pbrd)
for svc in zebra staticd bfdd pbrd; do
    if grep -q "^${svc}=no" /etc/frr/daemons 2>/dev/null; then
        sed -i "s/^${svc}=no/${svc}=yes/" /etc/frr/daemons
    fi
done

echo "Starting FRR..."
service frr start

# Wait for FRR daemons to be ready (vtysh can connect)
echo "Waiting for FRR daemons..."
for i in $(seq 1 30); do
    if vtysh -c "show version" 2>/dev/null | grep -q "FRRouting"; then
        echo "FRR ready (vtysh connected)"
        break
    fi
    if [ "$i" -eq 30 ]; then
        echo "WARNING: FRR vtysh not ready after 30s, continuing anyway"
    fi
    sleep 1
done

# Install default routes with different kernel metrics so both WAN paths coexist
# in the routing table simultaneously.  The kernel selects the lowest metric
# (WAN1=10) for forwarding when both links are up.  When WAN1 goes down the
# kernel automatically removes the metric-10 route and falls back to metric-200
# (WAN2) with no FRR involvement.  This avoids the FRR staticd EEXIST race
# condition that occurs when two static routes share the same kernel metric (20).
#
# Gateways must match wan_gateways in bf_config_sdwan.json:
#   WAN1 gateway: 10.10.1.2  (eth-wan1, metric 10  — primary)
#   WAN2 gateway: 10.10.2.2  (eth-wan2, metric 200 — backup)
echo "Installing kernel default routes with differentiated metrics..."
ip route replace default via 10.10.1.2 dev eth-wan1 metric 10  proto static 2>/dev/null || true
ip route replace default via 10.10.2.2 dev eth-wan2 metric 200 proto static 2>/dev/null || true
echo "Kernel routes installed: WAN1 metric=10 (primary), WAN2 metric=200 (backup)"

# Use iptables-legacy if available (some images have nft as default)
if update-alternatives --list iptables 2>/dev/null | grep -q iptables-legacy; then
    update-alternatives --set iptables /usr/sbin/iptables-legacy 2>/dev/null || true
    update-alternatives --set ip6tables /usr/sbin/ip6tables-legacy 2>/dev/null || true
fi

# Phase 3.5: Start StrongSwan if IKEv2 certificates are mounted
if [ -f /etc/ipsec.d/certs/dut.crt ] && [ -f /etc/ipsec.d/private/dut.key ]; then
    echo "StrongSwan certificates detected — starting IPsec..."
    ipsec start 2>/dev/null || true
    sleep 2
    if ipsec statusall 2>/dev/null | grep -q "ESTABLISHED\|Security Associations"; then
        echo "StrongSwan: IKEv2 tunnel ESTABLISHED"
    else
        echo "WARNING: StrongSwan started but tunnel not yet established (peer may not be running)"
    fi
else
    echo "StrongSwan certificates not mounted — skipping IPsec (Phase 3 mode)"
fi

echo "SD-WAN router ready. Starting SSH..."
exec /usr/sbin/sshd -D
