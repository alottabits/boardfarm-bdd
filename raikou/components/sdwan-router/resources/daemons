# FRR daemons for SD-WAN Router (Dual WAN, BFD failover, PBR steering)
# zebra + staticd + bfdd (BFD echo mode for sub-second failover)
# pbrd (Policy-Based Routing for LinuxSDWANRouter.apply_policy)
#
# See: docs/LinuxSDWANRouter_Implementation_Plan.md §3.2.1

zebra=yes
staticd=yes
bfdd=yes
pbrd=yes

bgpd=no
ospfd=no
ospf6d=no
ripd=no
ripngd=no
isisd=no
pimd=no
pim6d=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
fabricd=no
vrrpd=no
pathd=no

vtysh_enable=yes
zebra_options=" -A 127.0.0.1 -s 90000000"
staticd_options="-A 127.0.0.1"
bfdd_options=" -A 127.0.0.1"
pbrd_options="-A 127.0.0.1"
