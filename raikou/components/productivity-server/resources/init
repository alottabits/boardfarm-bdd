#!/bin/sh
#
# Productivity Server init — start fcgiwrap, nginx, sshd
# Raikou OVS injects eth1 (north-segment). Single interface — no content-internal.
#
set -e

# Wait for eth1 (north-segment) and add route for LAN clients via TC
count=0
while [ $count -lt 30 ]; do
    if ip addr show eth1 2>/dev/null | grep -q "inet "; then
        ip route add 192.168.10.0/24 via 172.16.0.1 dev eth1 2>/dev/null || true
        ip route add 10.10.1.0/30 via 172.16.0.1 dev eth1 2>/dev/null || true
        ip route add 10.10.2.0/30 via 172.16.0.1 dev eth1 2>/dev/null || true
        break
    fi
    sleep 1
    count=$((count + 1))
done

mkdir -p /var/run/fcgiwrap
chown nginx:nginx /var/run/fcgiwrap

# Run fcgiwrap as nginx so nginx can connect to the socket
spawn-fcgi -s /var/run/fcgiwrap/fcgiwrap.sock -f /usr/bin/fcgiwrap -u nginx -g nginx -M 660 -- &
sleep 1

# Start nginx (productivity on 8080)
nginx -g "daemon off;" &
sleep 1

# Start SSH for Boardfarm
exec /usr/sbin/sshd -D
