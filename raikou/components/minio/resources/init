#!/bin/sh
#
# MinIO init — configure Raikou-injected eth1 (content-internal), then start MinIO.
# Raikou OVS topology: eth1 gets 10.100.0.2/30 on content-internal bridge.
# If Raikou doesn't assign the IP, we configure it here.
#
set -e

# Wait for eth1 (Raikou content-internal bridge)
count=0
while [ $count -lt 60 ]; do
    if [ -d "/sys/class/net/eth1" ]; then
        ip link set eth1 up
        # Configure IP if not already set (Raikou may or may not assign it)
        if ! ip addr show eth1 2>/dev/null | grep -q "inet 10.100.0.2"; then
            ip addr add 10.100.0.2/30 dev eth1 2>/dev/null || true
        fi
        break
    fi
    sleep 2
    count=$((count + 1))
done

mkdir -p /data
exec /usr/local/bin/minio server /data
